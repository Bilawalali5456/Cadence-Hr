# Copy this file to .env and update with your PostgreSQL credentials
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/adforce_hr
PORT=4000
NODE_ENV=production

# Email (Hostinger: smtp.hostinger.com, port 465)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hr@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM=Adforce HR <hr@yourdomain.com>
APP_URL=https://hr.yourdomain.com
